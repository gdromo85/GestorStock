# =============================================================================
# GestorStock — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Backend ---
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000

# --- Database (PostgreSQL on VPS) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&connection_limit=20&sslmode=require
DATABASE_URL=postgres://postgres:Guille0401@152.53.141.41:2001/gestion-stock?schema=public

# --- JWT Secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# --- Admin Seed (used by prisma db seed) ---
ADMIN_EMAIL=admin@gestorstock.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Administrator
